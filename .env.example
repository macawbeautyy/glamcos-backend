# ============================================================
# GLAMCOS / MACAW Platform — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=5000
API_VERSION=v1

# --- MongoDB ---
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRE=30d

# --- CORS ---
CORS_ORIGIN_USER_APP=http://localhost:8081
CORS_ORIGIN_PROVIDER_APP=http://localhost:8082
CORS_ORIGIN_MARKETPLACE_APP=http://localhost:8083
CORS_ORIGIN_ADMIN_PANEL=http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- File Upload ---
MAX_FILE_UPLOAD=5000000
FILE_UPLOAD_PATH=./public/uploads

# --- Firebase Admin SDK ---
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=logs/app.log
